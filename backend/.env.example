# ──────────────────────────────────────────────────────
# NCC Website Backend – Environment Configuration
# ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=your-very-secret-random-key-here
CACHE_REDIS_URL=redis://localhost:6379/0  # Optional (if using Redis for Flask-Caching instead of SimpleCache)

# ── Email (SMTP via Gmail) ────────────────────────────
# To enable real email sending:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Create an "App Password" for "Mail"
#   3. Paste the 16-character password below (no spaces)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=NCC GPH Hamirpur <your-gmail-address@gmail.com>

# ── Database (optional – SQLite is used by default) ───
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/ncc_db
