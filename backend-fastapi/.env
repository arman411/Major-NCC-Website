# ── MySQL Database ─────────────────────────────────────────────────────────────
# Format: mysql+aiomysql://user:password@host:port/dbname
MYSQL_URI=mysql+aiomysql://root:@localhost:3306/ncc_hamirpur

# ── JWT Secret ─────────────────────────────────────────────────────────────────
# Change this to a long random string in production!
SECRET_KEY=ncc-gph-hamirpur-super-secret-jwt-key-2025
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SMTP Email (optional — leave blank to disable email in dev) ────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=NCC GPH Hamirpur <noreply@gph.edu.in>

# ── Uploads ────────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE_MB=10

# ── CORS — frontend URL (comma-separated) ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500,http://localhost:8080,http://127.0.0.1:8080

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=true
